DATABASE_URL=postgresql://fitme:fitme@localhost:5432/fitme
REDIS_URL=redis://localhost:6379
STORAGE_PROVIDER=gcs
GCS_BUCKET=fitme-assets
GCS_PROJECT_ID=your-gcp-project-id
GCS_PUBLIC_BASE_URL=https://storage.googleapis.com/fitme-assets
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=fitme-assets
JWT_SECRET=replace-me
PORT=3001
ADMIN_WEB_PORT=3000
EXPO_PUBLIC_API_URL=http://localhost:3001
EXPO_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_API_URL=http://localhost:3001
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
CUELINKS_SOURCE_ID=
INSTAGRAM_TRENDS_ENABLED=false
INSTAGRAM_GRAPH_APPROVED=false
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=
TRYON_PROVIDER=gemini
TRYON_HTTP_BASE_URL=http://localhost:4010
ENABLE_PREMIUM_FEATURES=false
TRYON_FREE_DAILY_LIMIT=3
TRYON_PREMIUM_DAILY_LIMIT=20
# Set TRYON_PROVIDER=gemini and add GEMINI_API_KEY to enable Gemini virtual try-on.
# ANTHROPIC_API_KEY adds the fit/style analysis that is shown alongside the generated image.
# Premium credit enforcement is scaffolded only. Keep ENABLE_PREMIUM_FEATURES=false until payment/entitlement sync exists.
# Instagram trends are optional. Keep disabled until Graph API permissions and hashtag limits are approved.
# Set TRYON_PROVIDER=grok and add your xAI key only if you intentionally want Grok Aurora virtual try-on.
GROK_API_KEY=
# Set to true to use grok-imagine-image-pro (higher quality, slower, higher cost)
GROK_USE_PRO=false
