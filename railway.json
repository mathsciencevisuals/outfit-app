{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "apps/api/Dockerfile",
    "watchPatterns": [
      "apps/api/**",
      "packages/ai-client/**",
      "packages/config/**",
      "packages/fit-engine/**",
      "packages/recommendation-engine/**",
      "packages/types/**",
      "pnpm-lock.yaml",
      "pnpm-workspace.yaml",
      "package.json",
      "tsconfig.json"
    ]
  }
}
