{
  "name": "@fitme/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo export",
    "check:android-local": "node ./scripts/check-local-android-build.js",
    "build:apk": "eas build -p android --profile preview",
    "build:apk:local": "pnpm check:android-local && eas build --platform android --profile preview --local",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "node -e \"console.log('No tests configured for @fitme/mobile yet')\""
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.3",
    "@fitme/config": "workspace:*",
    "@fitme/ui": "workspace:*",
    "@react-native-async-storage/async-storage": "^1.23.1",
    "expo": "~51.0.28",
    "expo-constants": "~16.0.2",
    "expo-font": "~12.0.9",
    "expo-image-picker": "~15.1.0",
    "expo-linking": "~6.3.1",
    "expo-router": "~3.5.23",
    "expo-status-bar": "~1.12.1",
    "expo-web-browser": "~13.0.3",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "~3.31.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "~18.2.79",
    "typescript": "^5.6.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@fitme/api",
        "prisma",
        "@prisma/client"
      ]
    }
  }
}
