{
  "cli": {
    "version": ">= 14.3.0",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "environment": "preview",
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://fitmeapi-production.up.railway.app",
        "PRISMA_GENERATE_SKIP_AUTOINSTALL": "true"
      },
      "android": {
        "image": "latest",
        "buildType": "apk"
      }
    },
    "production": {
      "env": {
        "NODE_ENV": "production",
        "EXPO_PUBLIC_API_URL": "https://fitmeapi-production.up.railway.app",
        "PRISMA_GENERATE_SKIP_AUTOINSTALL": "true"
      },
      "android": {
        "image": "latest",
        "buildType": "app-bundle"
      }
    }
  }
}
