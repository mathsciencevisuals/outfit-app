# ─── FitMe Mobile — Environment Variables ────────────────────────────────────
#
# LOCAL DEV:  copy this file to .env.local  →  cp .env.example .env.local
# RAILWAY:    add each variable under your mobile service → Variables tab
# EAS BUILD:  variables are injected via eas.json → build → env (see eas.json)
#
# ─────────────────────────────────────────────────────────────────────────────

# The deployed base URL of your @fitme/api Railway service.
# Find it: Railway dashboard → api service → Settings → Domains
# Example: https://fitme-api-production.up.railway.app
EXPO_PUBLIC_API_URL=https://YOUR_RAILWAY_API_URL.railway.app
