{
  "name": "fitme",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @fitme/api prisma:generate",
    "db:migrate": "pnpm --filter @fitme/api prisma:migrate",
    "db:seed": "pnpm --filter @fitme/api prisma:seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "@nestjs/core",
      "@scarf/scarf",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "turbo": "^2.0.12",
    "typescript": "^5.6.3"
  }
}
